{
  "name": "reasoning-trace-vis",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "manifest": "node generate-manifest.js",
    "prestart": "npm run manifest",
    "start": "ng serve",
    "prebuild": "npm run manifest",
    "build": "ng build",
    "build:public": "PUBLIC_ONLY=true npm run build",
    "deploy:public": "npm run build:public && npx netlify deploy --dir=dist/reasoning-trace-vis/browser --prod --no-build",
    "deploy": "npm run build && npx netlify deploy --dir=dist/reasoning-trace-vis/browser --prod --no-build",
    "deploy:draft": "npm run build && npx netlify deploy --dir=dist/reasoning-trace-vis/browser --no-build",
    "prewatch": "npm run manifest",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@huggingface/transformers": "^4.2.0",
    "@types/d3": "^7.4.3",
    "3d-force-graph": "^1.80.0",
    "d3": "^7.9.0",
    "katex": "^0.16.45",
    "marked": "^18.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
